# ── OpenRouter (replaces individual OpenAI/Anthropic/Google keys) ──────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# ── Optional: override which models are used per task ─────────────────────────
# MODEL_GPT=openai/gpt-4o
# MODEL_CLAUDE=anthropic/claude-sonnet-4-5
# MODEL_GEMINI=google/gemini-pro-1.5
# MODEL_EXTRACT=anthropic/claude-haiku-4-5
# MODEL_GAP=anthropic/claude-sonnet-4-5

# ── CORS: comma-separated list of allowed frontend origins ────────────────────
# ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# ── OpenRouter attribution headers (optional but recommended) ─────────────────
# SITE_URL=http://localhost:5173
# SITE_NAME=AEO Diagnostic
